# Project Settings
PROJECT_NAME="Distributed Job Scheduling Platform"
LOG_LEVEL=INFO

# Database Configuration
# For local running outside docker, use localhost:5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/job_platform
# DB admin URL for running migrations or direct setups if needed
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/job_platform

# Security & Authentication
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=949f57fbe13645b2b2a63d9a562473491ba6fb3bf39d1b09b5523a5de033f20a
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_TOKENS_PER_MINUTE=60

# Worker Settings
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
REAP_THRESHOLD_SECONDS=15
